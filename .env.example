# =========================================================================
#  AI CONCIERGE CONFIG  (the on-site chat bot)
# =========================================================================
# The bot talks to an OpenAI-compatible chat endpoint. By default it is
# wired to GROQ, which has a generous FREE tier (no credit card) and runs
# fast open models like Llama 3.3 70B. You can swap to any OpenAI-compatible
# provider by changing the three vars below — no code changes needed.
#
# --- Option A: GROQ (recommended free default) ---------------------------
#   1. Sign up at https://console.groq.com  (free)
#   2. Create an API key
#   3. Paste it below
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=
AI_MODEL=llama-3.3-70b-versatile

# --- Option B: Google Gemini (also free) ---------------------------------
#   AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   AI_API_KEY=your_gemini_key
#   AI_MODEL=gemini-2.0-flash
#
# --- Option C: OpenRouter (free models available) ------------------------
#   AI_BASE_URL=https://openrouter.ai/api/v1
#   AI_API_KEY=your_openrouter_key
#   AI_MODEL=meta-llama/llama-3.3-70b-instruct:free
#
# NOTE: If AI_API_KEY is left blank, the bot still works in "guided mode" —
# it answers from the built-in knowledge base (lib/knowledge.ts) with smart
# canned replies, so the widget is never broken during a demo.
